# Required for Brave search integration.
BRAVE_API_KEY=replace_with_real_brave_api_key

# Optional. If your key is stored under a different env var name,
# set this to that variable name and keep the secret value in that env var.
# BRAVE_API_KEY_ENV_VAR=BRAVE_API_KEY

# Optional. Override config path for harvest runtime.
# HARVEST_CONFIG_PATH=engines/deep-search/corpus-harvester/harvest.config.json
